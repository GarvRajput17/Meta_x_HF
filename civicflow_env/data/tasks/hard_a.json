  "planning_phases": [
    {
      "name": "base_structure",
      "objective": "Lay out the five-district structure with housing, economic uses, civic anchors, and protected land respected."
    },
    {
      "name": "services_and_access",
      "objective": "Ensure each district has the required neighbourhood amenities and mobility access, not just global counts."
    },
    {
      "name": "infrastructure_balance",
      "objective": "Keep all five infrastructure zones feasible while meeting greenery and district mix obligations."
    },
    {
      "name": "replanning",
      "objective": "Absorb sequential policy shocks by revising only affected districts and preserving valid structure elsewhere."
    },
    {
      "name": "final_validation",
      "objective": "Finish with a globally valid and district-balanced city plan after all shocks."
    }
  ],
