    {
      "name": "base_structure",
      "objective": "Lay out housing, commerce, and parks across North, Central, and South without breaking protected/wetland rules."
    },
    {
      "name": "services_and_access",
      "objective": "Place school, clinic, grocery, fire, transit, and park access so each district meets its local coverage targets."
    },
    {
      "name": "infrastructure_balance",
      "objective": "Keep each infrastructure zone feasible while maintaining greenery and mixed-use balance."
    },
    {
      "name": "replanning",
      "objective": "When policy shocks land, revise only the affected districts and preserve unaffected work."
    },
    {
      "name": "final_validation",
      "objective": "End with a valid, district-balanced plan that still satisfies the global targets."
    }
